# ==========================================

# SOLUCIÓN DE ÁREAS SEPARADAS (MULTI-POLÍGONOS)

# ==========================================

library(sf)
library(dplyr)

# PASOS 1 y 2: Calcular áreas y sumar las de los distritos repetidos

tabla_superficies <- distritos_sf %>%

  # Calculamos el área de cada "trozo" individual

  mutate(area_trozo_km2 = as.numeric(st_area(.)) / 1000000) %>%

  # Quitamos el mapa para poder agrupar matemáticamente

  st_drop_geometry() %>%

  # Agrupamos por el nombre del distrito

  group_by(nombre) %>%

  rename(distrito_limpio=nombre) %>%

  # Sumamos todas las áreas que compartan el mismo nombre

  summarise(area_total_km2 = sum(area_trozo_km2, na.rm = TRUE))



# (Opcional) Comprobación de seguridad: 

# Si ejecutas nrow(tabla_superficies) en la consola, ¡ahora te dará exactamente 19!



# PASO 3: Juntar resultados y calcular densidades espaciales

densidad_transportes <- densidad_transportes %>%

  # Hacemos el join (ahora encajará 1 a 1 de forma perfecta)

  left_join(tabla_superficies, by = "distrito_limpio") %>%

  # Calculamos las nuevas variables usando el área total

  mutate(

    paradas_por_km2 = Total_Transporte / area_total_km2,

    score_transporte_pesado = (FGV * 3 + EMT * 2 + Valenbisi * 1) / area_total_km2

  )



##########################################################################################################

# --- 4. VISUALIZACIÓN DE DATOS ---



# 4.1. Preparamos los datos: Densidad de cada transporte por km2

densidad_transportes <- densidad_transportes %>%

  mutate(

    dens_EMT_km2 = EMT / area_total_km2,

    dens_FGV_km2 = FGV / area_total_km2,

    dens_Valenbisi_km2 = Valenbisi / area_total_km2

  )



# 4.2. Transformamos la tabla para ggplot (formato largo)

df_grafico <- densidad_transportes %>%

